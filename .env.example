# Copy to backend/.env and fill in. Never commit the real file.

# ─── App access (the password gate) ───────────────────────────────────────────
ENVIRONMENT=production
APP_PASSWORD=INSERT_A_REAL_PASSWORD_HERE
# Generate with:  openssl rand -hex 32
SESSION_SECRET=INSERT_A_LONG_RANDOM_SECRET_HERE

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
# Where the SQLite DB and any local-fallback invoices live (kept out of git).
DB_PATH=/opt/apps/reno-tracker/data/expenses.db
DATA_DIR=/opt/apps/reno-tracker/data
MAX_UPLOAD_MB=25

# ─── Google Drive (invoice storage — scope: drive.file) ───────────────────────
# OAuth client from Google Cloud Console (type: Desktop app).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
# Mint this once by running backend/authorize_drive.py on a machine with a
# browser, then paste the printed value here. See README "Google Drive setup".
GOOGLE_REFRESH_TOKEN=xxxxxxxx
# Optional overrides:
# DRIVE_FOLDER_NAME=House Invoices
# DRIVE_FOLDER_ID=          # set to skip the by-name folder lookup on each boot
